NODE_ENV=production

# GitHub private release access
VOTER_SERVICE_UPDATE_GITHUB_TOKEN=ghp_replace_me
VOTER_SERVICE_UPDATE_GITHUB_OWNER=Sterio068
VOTER_SERVICE_UPDATE_GITHUB_REPO=voter-service-system

# Public URL that desktop apps will call
VOTER_SERVICE_UPDATE_PROXY_URL=https://updates.example.com

# Local listen address for the proxy process
VOTER_SERVICE_UPDATE_PROXY_HOST=127.0.0.1
VOTER_SERVICE_UPDATE_PROXY_PORT=8787

# Optional shared bearer token between desktop app and proxy
VOTER_SERVICE_UPDATE_PROXY_TOKEN=replace-with-a-long-random-token
