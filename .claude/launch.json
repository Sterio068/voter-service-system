{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend API Server",
      "runtimeExecutable": "/opt/homebrew/bin/npm",
      "runtimeArgs": ["run", "dev:server"],
      "port": 8080
    },
    {
      "name": "Frontend Vite Dev Server",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": [".claude/start-client.sh"],
      "port": 5173
    },
    {
      "name": "All (Backend + Frontend + Electron)",
      "runtimeExecutable": "/opt/homebrew/bin/npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    }
  ]
}
