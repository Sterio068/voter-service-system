{
  "name": "voter-service-system",
  "version": "1.0.0",
  "description": "本地單機版選民服務管理系統",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:client && npm run build:main && npm run build:preload",
    "build:client": "vite build",
    "build:main": "node scripts/build-electron.mjs",
    "build:preload": "node scripts/build-preload.mjs",
    "build:icons": "node scripts/generate-icons.mjs",
    "pack": "npm run build:icons && npm run build && electron-builder",
    "dist:win": "npm run build:icons && npm run build && electron-builder --win",
    "dist:mac": "npm run build:icons && npm run build && electron-builder --mac",
    "dist:all": "npm run build:icons && npm run build && electron-builder --win --mac",
    "db:migrate": "tsx server/db/migrate.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.1.0",
    "@fastify/static": "^7.0.3",
    "@fullcalendar/daygrid": "^6.1.11",
    "@fullcalendar/interaction": "^6.1.11",
    "@fullcalendar/react": "^6.1.11",
    "@fullcalendar/timegrid": "^6.1.11",
    "antd": "^5.14.0",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.8.0",
    "dayjs": "^1.11.10",
    "electron-updater": "^6.1.8",
    "fastify": "^4.26.2",
    "googleapis": "^171.4.0",
    "ip": "^2.0.1",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.25.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "tw.voter.service.system",
    "productName": "選民服務系統",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!node_modules/.vite/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "選民服務系統",
      "installerLanguages": [
        "zh_TW"
      ],
      "language": "1028",
      "installerHeaderIcon": "resources/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "title": "選民服務系統安裝",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
