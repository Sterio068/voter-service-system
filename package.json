{
  "name": "voter-service-system",
  "version": "1.0.29",
  "description": "本地單機版選民服務管理系統",
  "license": "AGPL-3.0-only",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:update-proxy": "tsx watch server/updateProxyServer.ts",
    "dev:client": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:update-proxy-config && npm run build:client && npm run build:main && npm run build:preload",
    "build:update-proxy-config": "node scripts/generate-update-proxy-config.mjs",
    "build:client": "vite build",
    "build:main": "node scripts/build-electron.mjs",
    "build:preload": "node scripts/build-preload.mjs",
    "build:icons": "node scripts/generate-icons.mjs",
    "typecheck": "npm run typecheck:client && npm run typecheck:server && npm run typecheck:electron && npm run typecheck:test",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "verify": "npm run typecheck && npm test && npm run build && npm run audit:prod",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "restore:native": "npm rebuild better-sqlite3 bcrypt",
    "pack": "npm run build:icons && npm run build && electron-builder && npm run restore:native",
    "dist:win": "npm run build:icons && npm run build && electron-builder --win && npm run restore:native",
    "dist:mac": "npm run build:icons && npm run build && electron-builder --mac && npm run restore:native",
    "dist:all": "npm run build:icons && npm run build && electron-builder --win --mac && npm run restore:native",
    "db:migrate": "tsx server/db/migrate.ts",
    "start:update-proxy": "tsx server/updateProxyServer.ts",
    "test": "node scripts/run-node-tests.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "@e965/xlsx": "^0.20.3",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@fullcalendar/daygrid": "^6.1.11",
    "@fullcalendar/interaction": "^6.1.11",
    "@fullcalendar/react": "^6.1.11",
    "@fullcalendar/timegrid": "^6.1.11",
    "@types/pdfmake": "^0.3.2",
    "@types/qrcode": "^1.5.6",
    "antd": "^5.14.0",
    "axios": "^1.6.7",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "dayjs": "^1.11.10",
    "docx": "^9.6.1",
    "electron-updater": "^6.1.8",
    "fastify": "^5.8.4",
    "googleapis": "^171.4.0",
    "openai": "^6.33.0",
    "pdfmake": "^0.3.7",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.2",
    "zod": "^4.3.6",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "tw.voter.service.system",
    "productName": "選民服務系統",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Sterio068",
        "repo": "voter-service-system"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bcrypt/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/fonts",
        "to": "fonts",
        "filter": [
          "**/*.ttf",
          "**/*.otf"
        ]
      },
      {
        "from": "generated-resources/update-proxy.json",
        "to": "update-proxy.json",
        "filter": [
          "update-proxy.json"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!node_modules/.vite/**",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!**/.env",
      "!**/.env.*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "artifactName": "voter-service-system-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "選民服務系統",
      "installerLanguages": [
        "zh_TW"
      ],
      "language": "1028",
      "installerHeaderIcon": "resources/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "title": "選民服務系統安裝",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
